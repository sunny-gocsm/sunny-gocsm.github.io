{
  "name": "@gocsm/design-system",
  "version": "1.1.2",
  "description": "GoCSM Design System v3 — React component library, tokens, and adherence lint.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles.css",
    "./tokens": "./src/tokens/"
  },
  "files": [
    "dist",
    "src/styles.css",
    "src/styles",
    "src/tokens",
    "src",
    "styles.css"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup src/index.js --format esm,cjs --external react --external react-dom --external lucide-react --clean",
    "lint": "oxlint --config .oxlintrc.json src",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "lucide-react": ">=0.300.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "lucide-react": "^1.18.0",
    "oxlint": "^0.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0"
  },
  "dependencies": {
    "@types/react": "^18.3.31",
    "typescript": "^5.9.3"
  }
}

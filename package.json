{
  "name": "gocsm",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '@gocsm/prototype' dev",
    "dev:web": "bun --filter '@gocsm/web' dev",
    "build": "bun --filter '@gocsm/design-system' build && bun --filter '@gocsm/prototype' build && bun --filter '@gocsm/web' build",
    "build:ds": "bun --filter '@gocsm/design-system' build",
    "build:app": "bun --filter '@gocsm/prototype' build",
    "build:web": "bun --filter '@gocsm/web' build",
    "lint": "bun --filter '*' lint"
  }
}
